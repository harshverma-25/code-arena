{
  // Visit https://aka.ms/tsconfig to read more about this file
  "compilerOptions": {
    // File Layout — compiled output goes to dist/, never inside src/
    "rootDir": "./src",
    "outDir": "./dist",

    // Environment Settings
    "module": "nodenext",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "target": "esnext",

    // Node types only — no browser or React types needed on the backend
    "lib": ["esnext"],
    "types": ["node"],

    // Output artefacts
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,

    // Strict type-checking
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,

    // Module handling
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "skipLibCheck": true
  },

  // Only compile files inside src/
  // prisma.config.ts is intentionally excluded — it is used only by the
  // Prisma CLI (prisma migrate / prisma generate), not by tsc.
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
